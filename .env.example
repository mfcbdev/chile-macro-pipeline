# BDE (Banco Central de Chile) API credentials
# Register at: https://si3.bcentral.cl/estadisticas/principal1/web_services/index.htm
# NEVER commit real values. In production these come from Secret Manager.
BDE_USER=your_bde_username
BDE_PASSWORD=your_bde_password

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=chile-macro-raw

# Local dev only (path to service account JSON if not using ADC)
# GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json
